{
  "manifest_version": 3,
  "name": "TidyPaper",
  "description": "Route recognized paper PDFs into categorized folders under Downloads/Papers.",
  "version": "0.2.0",
  "permissions": [
    "downloads",
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  }
}
